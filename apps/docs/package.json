{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Docusaurus/Storybook documentation app",
  "scripts": {
    "docs:build": "docusaurus build",
    "docs:dev": "docusaurus start --port 3001",
    "docs:clear": "docusaurus clear",
    "build": "docusaurus build",
    "build-storybook": "storybook build",
    "build:site": "pnpm run build:vue-demo && storybook build -o static/storybook && docusaurus build",
    "storybook": "storybook dev --port 6006",
    "visual:test": "playwright test",
    "visual:update-baseline": "playwright test --update-snapshots",
    "test": "echo TODO",
    "gen:api": "node scripts/gen-api.mjs",
    "build:vue-demo": "pnpm --filter @topgrid/grid-pro-chart-enterprise-vue exec esbuild demo/main.ts --bundle --format=esm --outfile=../../apps/docs/static/vue-chart-demo/app.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/preset-classic": "^3.0.0",
    "@docusaurus/types": "^3.0.0",
    "@playwright/test": "^1.40",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "autoprefixer": "^10.5.2",
    "axe-core": "^4.12.0",
    "docusaurus-plugin-typedoc": "^1.0.0",
    "playwright": "^1.40",
    "postcss": "^8.5.15",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "storybook": "^8.0.0",
    "tailwindcss": "^3",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.0.0"
  }
}
