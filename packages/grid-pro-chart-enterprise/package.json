{
  "name": "@topgrid/grid-pro-chart-enterprise",
  "version": "0.3.0",
  "type": "module",
  "license": "SEE LICENSE IN EULA",
  "publishConfig": {
    "access": "public"
  },
  "description": "Pro: Enterprise charting (Apache ECharts adapter) over the grid-pro-chart range/pivot bridge",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo \"chromium-gated (tests/visual/enterprise-chart.spec.ts); pure engine tested in @topgrid/grid-chart-core\""
  },
  "dependencies": {
    "@topgrid/grid-chart-core": "workspace:*",
    "@topgrid/grid-license": "workspace:*",
    "@topgrid/grid-pro-chart": "workspace:*"
  },
  "peerDependencies": {
    "echarts": "^5.5.0 || ^6.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "echarts": "^6.0.0"
  }
}
