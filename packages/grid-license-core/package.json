{
  "name": "@topgrid/grid-license-core",
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN EULA",
  "publishConfig": {
    "access": "public"
  },
  "description": "Framework-neutral license state + verification for TopGrid (no React/Vue). Source of the license singleton.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "grid",
    "datagrid",
    "table",
    "tanstack-table",
    "data-table",
    "headless",
    "license"
  ]
}
