{
  "name": "@topgrid/grid-core",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "description": "TanStack Table abstraction wrapper + useGridState core hook",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./legacy": {
      "types": "./dist/legacy/index.d.ts",
      "import": "./dist/legacy/index.mjs",
      "require": "./dist/legacy/index.cjs"
    },
    "./internal/storage": {
      "types": "./dist/internal/storage/index.d.ts",
      "import": "./dist/internal/storage/index.mjs",
      "require": "./dist/internal/storage/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types src/internal/moveRow.test.ts"
  },
  "devDependencies": {
    "@topgrid/grid-renderers": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alladins/topgrid.git",
    "directory": "packages/grid-core"
  },
  "bugs": {
    "url": "https://github.com/alladins/topgrid/issues"
  },
  "homepage": "https://github.com/alladins/topgrid#readme",
  "publishConfig": {
    "access": "public"
  }
}
