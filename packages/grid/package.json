{
  "name": "@topgrid/grid",
  "version": "0.3.0",
  "type": "module",
  "license": "SEE LICENSE IN EULA",
  "publishConfig": {
    "access": "public"
  },
  "description": "Meta package — aggregates all @topgrid/grid-* packages (MIT + Pro facade)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": [
    "./src/index.ts",
    "./dist/index.mjs",
    "./dist/index.cjs"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo TODO"
  },
  "dependencies": {
    "@topgrid/grid-core": "workspace:*",
    "@topgrid/grid-renderers": "workspace:*",
    "@topgrid/grid-features": "workspace:*",
    "@topgrid/grid-export": "workspace:*",
    "@topgrid/grid-license": "workspace:*",
    "@topgrid/grid-pro-tracking": "workspace:*",
    "@topgrid/grid-pro-range": "workspace:*",
    "@topgrid/grid-pro-datamap": "workspace:*",
    "@topgrid/grid-pro-merging": "workspace:*",
    "@topgrid/grid-pro-header": "workspace:*",
    "@topgrid/grid-pro-agg": "workspace:*",
    "@topgrid/grid-pro-master": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "jspdf": "^2.5.0",
    "jspdf-autotable": "^3.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "xlsx": "^0.18.5"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-virtual": {
      "optional": true
    },
    "jspdf": {
      "optional": true
    },
    "jspdf-autotable": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  }
}
