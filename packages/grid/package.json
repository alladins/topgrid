{
  "name": "@tomis/grid",
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN EULA",
  "private": true,
  "description": "Meta package — aggregates all @tomis/grid-* packages (MIT + Pro facade)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": [
    "./src/index.ts",
    "./dist/index.mjs",
    "./dist/index.cjs"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "echo TODO"
  },
  "dependencies": {
    "@tomis/grid-core": "workspace:*",
    "@tomis/grid-renderers": "workspace:*",
    "@tomis/grid-features": "workspace:*",
    "@tomis/grid-export": "workspace:*",
    "@tomis/grid-license": "workspace:*",
    "@tomis/grid-pro-tracking": "workspace:*",
    "@tomis/grid-pro-range": "workspace:*",
    "@tomis/grid-pro-datamap": "workspace:*",
    "@tomis/grid-pro-merging": "workspace:*",
    "@tomis/grid-pro-header": "workspace:*",
    "@tomis/grid-pro-agg": "workspace:*",
    "@tomis/grid-pro-master": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.0.0",
    "@tanstack/react-virtual": "^3.0.0",
    "jspdf": "^2.5.0",
    "jspdf-autotable": "^3.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "xlsx": "^0.18.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-virtual": {
      "optional": true
    },
    "jspdf": {
      "optional": true
    },
    "jspdf-autotable": {
      "optional": true
    },
    "xlsx": {
      "optional": true
    }
  }
}