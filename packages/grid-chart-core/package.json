{
  "name": "@topgrid/grid-chart-core",
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN EULA",
  "publishConfig": {
    "access": "public"
  },
  "description": "Framework-neutral chart engine: labelled matrix → Apache ECharts option (no React/Vue; echarts type-only)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types src/internal/matrixToEChartsOption.test.ts"
  },
  "peerDependencies": {
    "echarts": "^5.5.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    }
  },
  "devDependencies": {
    "echarts": "^6.0.0"
  }
}
