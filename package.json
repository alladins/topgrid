{
  "name": "topgrid-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter \"@topgrid/*\" --workspace-concurrency=1 build",
    "typecheck": "pnpm -r --filter './packages/*' exec tsc --noEmit",
    "test": "pnpm -r test",
    "visual:test": "pnpm -F docs visual:test",
    "size": "pnpm build && size-limit",
    "size-limit": "size-limit",
    "size-limit:ci": "size-limit --json",
    "lint": "eslint packages apps",
    "changeset": "changeset"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-datepicker": "8.3.0",
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.25.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@tanstack/react-table": "^8",
    "@tanstack/react-virtual": "^3.13.24",
    "@tanstack/table-core": "^8",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "date-fns": "^4.1.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "react": "^18",
    "react-datepicker": "^8.3.0",
    "react-dom": "^18",
    "size-limit": "^11.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
